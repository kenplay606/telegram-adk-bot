# AI Agency Suite - Environment Variables Template
# SECURITY: Copy this to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================
# CORE SETTINGS
# ============================================
APP_NAME=AI Agency Suite
DEBUG=True
SECRET_KEY=your-secret-key-here-change-this

# ============================================
# OLLAMA (Local AI - Required)
# ============================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT=120

# ============================================
# OPTIONAL: OPENROUTER (Cloud AI - Free Tier)
# ============================================
# Get free API key from: https://openrouter.ai/keys
# Free models available: meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ============================================
# DATABASE
# ============================================
DATABASE_URL=sqlite:///./ai_agency.db
CHROMA_PERSIST_DIR=./chroma_db

# ============================================
# API SETTINGS
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your-api-key-for-external-access

# ============================================
# INSTAGRAM (Optional - for client automation)
# ============================================
# Get from: https://developers.facebook.com/
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_VERIFY_TOKEN=your-webhook-verify-token

# ============================================
# YOUTUBE (Optional - for personal content)
# ============================================
# Get from: https://console.cloud.google.com/
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ============================================
# FACEBOOK (Optional - for personal content)
# ============================================
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ============================================
# TEXT-TO-SPEECH
# ============================================
# Options: gtts (online, free) or pyttsx3 (offline)
TTS_ENGINE=gtts
TTS_LANGUAGE=en

# ============================================
# VIDEO SETTINGS
# ============================================
VIDEO_OUTPUT_DIR=./videos
THUMBNAIL_OUTPUT_DIR=./thumbnails
VIDEO_RESOLUTION=1080x1920
VIDEO_FPS=30

# ============================================
# SCHEDULER
# ============================================
SCHEDULER_ENABLED=True
SCHEDULER_TIMEZONE=America/New_York

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
