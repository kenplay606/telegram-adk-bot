# Google ADK Configuration
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=0

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_IDS=your_telegram_user_id_here

# Instructions:
# 1. Copy this file to my_agent/.env
# 2. Replace the placeholder values with your actual credentials
# 3. Get Google API key from: https://aistudio.google.com/apikey
# 4. Get Telegram bot token from: @BotFather on Telegram
# 5. Get your Telegram user ID from: @userinfobot on Telegram
